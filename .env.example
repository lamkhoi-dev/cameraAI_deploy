# 🔧 Configuration - Copy to .env and customize

# ============= VIDEO SOURCE =============
# Local video file (for testing)
# VIDEO_SOURCE=video1.mov

# RTSP stream from go2rtc (production)
# VIDEO_SOURCE=rtsp://localhost:8554/camera1

# RTSP stream from IP camera
# VIDEO_SOURCE=rtsp://admin:password@192.168.1.100:554/stream

# ============= BACKEND API =============
BACKEND_API_URL=http://localhost:8000
API_KEY=your-secret-api-key-here

# ============= DATABASE =============
# PostgreSQL connection (for production)
DATABASE_URL=postgresql://postgres:secure-password@postgres:5432/camera_db
POSTGRES_DB=camera_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=secure-password

# ============= LOGGING =============
LOG_LEVEL=INFO
LOG_FILE=logs/ai_engine.log

# ============= GPU CONFIGURATION =============
# CUDA device ID (usually 0)
CUDA_VISIBLE_DEVICES=0

# TensorRT optimization (after export_tensorrt.py)
USE_TENSORRT=false

# ============= go2rtc CONFIGURATION =============
# For RTSP camera streaming
GO2RTC_RTSP_LISTEN=:8554
GO2RTC_HTTP_LISTEN=:1984

# ============= TIMEZONE =============
TZ=Asia/Ho_Chi_Minh

# ============= OPTIONAL - Advanced =============
# Frame processing optimization
SKIP_FRAMES=3
FRAME_RESIZE_SCALE=0.5

# Model paths (relative to ai_engine/models/)
MODEL_POSE=yolo11s-pose.pt
MODEL_OBJECT=yolo11s.pt
MODEL_FIRE=yolo11n-fire.pt
MODEL_PLATE=yolo11n-plate.pt

# Detection thresholds
CONF_THRESHOLD=0.5
KEYPOINT_CONF_THRESHOLD=0.3
TRACK_CONF_THRESHOLD=0.4

# Fire detection
FIRE_TEMPORAL_THRESHOLD=3
FIRE_MINIMUM_AREA=100

# OCR settings
USE_OCR=true
OCR_CONFIDENCE_THRESHOLD=0.7

# ============= NOTIFICATIONS (optional) =============
# Slack integration for alerts
SLACK_WEBHOOK_URL=

# Email alerts
EMAIL_ALERTS_ENABLED=false
EMAIL_FROM=alerts@camera-system.local
EMAIL_TO=admin@example.com
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
