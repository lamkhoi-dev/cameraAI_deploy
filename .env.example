# ==============================================
# Camera Tracking AI — Environment Configuration
# Copy this file to .env and fill in real values
# NEVER commit .env to Git!
# ==============================================

# --- Database ---
DB_USER=postgres
DB_PASSWORD=changeme_in_production
DB_HOST=postgres
DB_PORT=5432
DB_NAME=ai_detection

# --- Backend ---
SECRET_KEY=change-this-secret-key-in-production
JWT_EXPIRE_HOURS=24
API_HOST=0.0.0.0
API_PORT=8000

# --- go2rtc ---
GO2RTC_API=http://localhost:1984
GO2RTC_CONFIG_PATH=./media_server/go2rtc.yaml

# --- Camera Defaults ---
CAMERA_ONBOARD_LIMIT=10
HIKVISION_USER=admin
HIKVISION_PASS=changeme
DAHUA_USER=admin
DAHUA_PASS=changeme

# --- Auth (change immediately after first login) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@2026!
OPERATOR_USERNAME=operator
OPERATOR_PASSWORD=Operator@2026!
