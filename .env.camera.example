# Cấu hình cho đặc biệt Camera Settings
NUM_COLORS_PERSON=3
NUM_COLORS_VEHICLE=5

# Cấu hình Stream
CAMERA_BUFFER_SIZE=1
CAMERA_FRAME_RATE=30
CAMERA_RESIZE_WIDTH=1280
CAMERA_RESIZE_HEIGHT=720

# Cấu hình JPEG Quality
JPEG_QUALITY=85

# Cấu hình Stream URL Examples
